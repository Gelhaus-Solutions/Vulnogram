                        .form-control
                            input.hid#cnaPresetPro(type="radio", name="cnaPreset", value="pro", onclick="setDefaultPropertiesPreset('cnaContainer', this.value)")
                            label.lbl.vgi-hat(for="cnaPresetPro") 1337
                    #defaultPropertiesCnaFields.pad.vflx
                div.vflx
                    b.lbl ADP container
                    .lbl Preset:
                    .rdg
                        .form-control
                            input.hid#adpPresetEnricher(type="radio", name="adpPreset", value="enricher", onclick="setDefaultPropertiesPreset('adpContainer', this.value)")
                            label.lbl.vgi-search(for="adpPresetEnricher") Enricher
                        .form-control
                            input.hid#adpPresetSupplier(type="radio", name="adpPreset", value="supplier", onclick="setDefaultPropertiesPreset('adpContainer', this.value)")
                            label.lbl.vgi-factory(for="adpPresetSupplier") Supplier
                    #defaultPropertiesAdpFields.pad.vflx
                div.vflx
