mixin dlgHeader(icon, msg)
    header.ban.sec.pad(style="min-width:20em;")
        b.lbl(class=icon)=msg
        | 
        a.rbtn.right.vgi-x(onclick="this.closest('dialog').close()")

mixin cveErrors
    +dlgHeader('vgi-alert', typeof err == 'string' ? 'Error' : err.error)
    center.pad2
        if typeof err == 'string'
            b.gap=err
        else
            h3=err.message
            if err.details
                ol.gap
                    each d, i in err.details
                        li= d.location
                            | /   
                            =d.param
                            | :  
                            =d.msg
mixin portal
    - var y = new Date().getFullYear()
    - var nextY = y+1
    - var selectedState = (typeof filterState !== 'undefined' && filterState !== null) ? String(filterState) : 'RESERVED'
    - var selectedYear = (typeof filterYear !== 'undefined' && filterYear !== null && filterYear !== '') ? String(filterYear) : String(y)
    header.pad.ban
        .left.flx
            label.vgi-globe.lbl Portal: 

                b=portalType
            span.btg.rnd
                        button.btn.vgi-magic(onclick='cveReserveAndRender(0)') Reserve One CVE
                        details.popup
                            summary.btn.t9 ▼
                            dl.pop.wht.bor.rnd.shd.rows
                              .gap
                                dt.flx
                                    button.btn.vgi-magic(onclick='cveReserveAndRender(0, 5)' style="min-width:6em") Reserve  5
                                    button.rbtn.right.vgi-x(onclick="this.closest('details').removeAttribute('open')")     
                                dt
                                    button.btn.vgi-magic(onclick='cveReserveAndRender(0, 10)'  style="min-width:6em") Reserve 10
                                dt
                                    .flx
                                        button.btn.vgi-magic(onclick="cveReserveAndRender(0, (parseInt(document.getElementById('reserveAmount').value,10)||1))" style="min-width:6em") Reserve
                                        |
                                        input#reserveAmount.lbl.txt(type="number", min="1", max="50", value="25", onclick="event.stopPropagation();", title="1–50 IDs", style="width:5em")
                                dt
                                    button.btn.vgi-magic(onclick='cveReserveAndRender(1)') Reserve one for 
                                        = y+1
                                dt
                                    button.btn.vgi-magic(onclick='cveReserveAndRender(-1)') Reserve one for 
                                        = y-1
                                dt
                                    - var reserveSelectedYear = selectedYear
                                    .flx
                                        button.btn.vgi-magic(onclick="cveReserveAndRender(((parseInt(document.getElementById('reserveSelectedYear').value, 10) || currentYear) - currentYear))")
                                            | Reserve one for &nbsp;
                                            span#reserveSelectedYearLabel=reserveSelectedYear
                                        |  
                                        select#reserveSelectedYear.lbl.txt(onclick='event.stopPropagation();' onchange="document.getElementById('reserveSelectedYearLabel').innerText=this.value")
                                            option(value=nextY selected=(reserveSelectedYear == String(nextY)))=nextY
                                            option(value=y selected=(reserveSelectedYear == String(y)))=y
                                            - var j = y-1
                                            while j > 1998
                                                option(value=j selected=(reserveSelectedYear == String(j)))=j
                                                - j--;

        if idQuota
            .flx#cveQuota(title="CVE ID quota for " + (org ? org.short_name : 'this org'))
                span.lbl.vgi-tag.nobr
                    span.tgrey Quota&nbsp;
                    b=idQuota.id_quota
                span.lbl.nobr
                    span.tgrey reserved&nbsp;
                    b=idQuota.total_reserved
                span.lbl.nobr(class=(typeof idQuota.available === 'number' && idQuota.available <= 0) ? 'tred' : '')
                    span.tgrey available&nbsp;
                    b=idQuota.available
        .flx
            label#cveUser
                +userstats
            if userInfo && userInfo.authority && userInfo.authority.active_roles && userInfo.authority.active_roles.includes("ADMIN")
                label#userMgmt
                    +usermgmt
    .pad#cveStatusMessage
    form#cvePortalFilter.gap(onchange='cveGetList();')
        .lbl Search
        span.txt-icon-wrap
            span.txt-input-icon.vgi-search
            input#cveSearchId.bor.txt.txt-has-icon(name="q", type="search", placeholder="CVE-YYYY-NNNN", autocomplete="off", onsearch="event.preventDefault();cveGetList();return false;", onkeydown="if(event.key==='Enter'){event.preventDefault();cveGetList();return false;}")
        .lbl Show
        .rdg
            .form-control
                input.hid(id="chkall" type="radio" name="fstate" value="" checked=(selectedState == ''))
                label.lbl.vgi-misc(for="chkall") All
            .form-control
                input.hid(id="chkres" type="radio" name="fstate" value="RESERVED" checked=(selectedState == 'RESERVED'))
                label.lbl.vgi-tag(for="chkres") Reserved
            .form-control
                input.hid(id="chkpub" type="radio" name="fstate" value="PUBLISHED" checked=(selectedState == 'PUBLISHED'))
                label.lbl.vgi-globe(for="chkpub") Published
            .form-control
                input.hid(id="chkrej" type="radio" name="fstate" value="REJECTED" checked=(selectedState == 'REJECTED'))
                label.lbl.vgi-del(for="chkrej") Rejected
        .lbl Year
        select.lbl.txt(name="y")
            option(value=nextY selected=(selectedYear == String(nextY)))=nextY
            option(value=y selected=(selectedYear == String(y)))=y
            - var i = y-1
            while i > 1998
                option(value=i selected=(selectedYear == String(i)))=i
                - i--;
        |  
        button.btn.vgi-reuse(onclick='event.preventDefault();cveGetList();return false;') Go
    div#cvePage.gap
        .rdg
            div.lbl#cvePageInfo
            .form-control
                button.lbl#prevPage(onclick='paginate(-1)') &#8249;
            .form-control
                div.lbl#currentPage 1
            .form-control
                button.lbl#nextPage(onclick='paginate(1)') &#8250;
		
    div#cveList.gap

