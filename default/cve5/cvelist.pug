                        td= u.name ? ((u.name.first||'') + ' ' + (u.name.last||'')) : ''
                        td.sml= u.username
                        td.sml= (u.authority && u.authority.active_roles) ? u.authority.active_roles.join(', ') : ''
                        td= u.active ? '✓' : '✗'
                        td
                            - var isAdmin = !!(u.authority && u.authority.active_roles && u.authority.active_roles.indexOf('ADMIN')>=0)
                            a.fbn.vgi-key(title="Reset API key" onclick="secResetUser('"+org.short_name+"','"+u.username+"')") &nbsp;
                            a.fbn.vgi-king(title=(isAdmin?'Remove admin':'Make admin') onclick="secToggleAdmin('"+org.short_name+"','"+u.username+"',"+(isAdmin?'true':'false')+")") &nbsp;
                            a.fbn(class=(u.active?'vgi-no':'vgi-ok'), title=(u.active?'Deactivate':'Activate') onclick="secToggleActive('"+org.short_name+"','"+u.username+"',"+(u.active?'true':'false')+")") &nbsp;
            else
                tr
                    td(colspan=5)
                        i No users.

mixin secRoleChecks
    label.lbl
        input(type="checkbox", name="role", value="CNA", checked=(typeof roles==='undefined' || roles.indexOf('CNA')>=0))
        |  CNA
    label.lbl
        input(type="checkbox", name="role", value="ADP", checked=(typeof roles!=='undefined' && roles.indexOf('ADP')>=0))
        |  ADP
    label.lbl
        input(type="checkbox", name="role", value="ROOT_CNA", checked=(typeof roles!=='undefined' && roles.indexOf('ROOT_CNA')>=0))
        |  ROOT_CNA
    label.lbl
        input(type="checkbox", name="role", value="SECRETARIAT", checked=(typeof roles!=='undefined' && roles.indexOf('SECRETARIAT')>=0))
        |  SECRETARIAT

mixin secCreateOrgForm
    form.sec.bor.rndx.pad.gap(onsubmit="return secCreateOrg(event, this);")
        b.lbl.vgi-add Create organization
        .vflx
            label.lbl(for="secNewShort") Short name
            input#secNewShort.bor.txt(name="short_name", required=true, pattern=".{2,32}", placeholder="acme_inc")
            label.lbl(for="secNewName") Name
            input#secNewName.bor.txt(name="name", required=true, placeholder="ACME, Inc.")
            label.lbl Roles
            .rdg
                +secRoleChecks
            label.lbl(for="secNewQuota") ID quota
            input#secNewQuota.bor.txt(name="id_quota", type="number", min="0", max="100000", value="100")
        .gap
            button.btn.sfe(type="submit") Create
            |
            button.btn.vgi-x(type="button", onclick="document.getElementById('secOrgCreate').classList.add('hid');document.getElementById('secOrgCreate').innerHTML='';") Cancel

mixin secEditOrgForm
    form.sec.bor.rndx.pad.gap(onsubmit="return secSubmitEditOrg(event, this, '"+org.short_name+"');")
        b.lbl.vgi-edit Edit
            =org.short_name
        .vflx
            label.lbl(for="secEditName") Name
            input#secEditName.bor.txt(name="name", value=org.name)
            label.lbl(for="secEditShort") New short name (optional)
            input#secEditShort.bor.txt(name="new_short_name", placeholder=org.short_name, pattern=".{2,32}")
            label.lbl Roles
            .rdg
                +secRoleChecks
            label.lbl(for="secEditQuota") ID quota
            input#secEditQuota.bor.txt(name="id_quota", type="number", min="0", max="100000", value=quota?quota.id_quota:'')
        .gap
            button.btn.sfe(type="submit") Save
            |
            button.btn.vgi-x(type="button", onclick="document.getElementById('secOrgDetail').querySelector('#secEditSlot') && (document.getElementById('secEditSlot').innerHTML='');") Cancel

mixin secAddUserForm
    form.sec.bor.rndx.pad.gap(onsubmit="return secSubmitAddUser(event, this, '"+shortName+"');")
        b.lbl.vgi-add Add user to
            =shortName
        .vflx
            label.lbl(for="secAuUser") Username
            input#secAuUser.bor.txt(name="username", required=true, pattern=".{3,128}", placeholder="jane@acme.example")
            label.lbl(for="secAuFirst") First name
            input#secAuFirst.bor.txt(name="first")
            label.lbl(for="secAuLast") Last name
            input#secAuLast.bor.txt(name="last")
