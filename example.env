MONGO_HOST=vulnogram-mongo
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_PORT=27017
# Optional full MongoDB connection URI override.
# When set, this takes precedence over MONGO_HOST/MONGO_PORT/MONGO_INITDB_ROOT_*.
#MONGO_URL=mongodb://admin:admin@vulnogram-mongo:27017
START_COMMAND=node init-vulnogram.js && node app.js
VULNOGRAM_ADMIN_CNA_EMAIL=security@example.com
VULNOGRAM_ADMIN_EMAIL=user@example.com
VULNOGRAM_ADMIN_NAME=Example User
VULNOGRAM_ADMIN_PASSWORD=vulnogram
VULNOGRAM_ADMIN_USERNAME=vulnogram
VULNOGRAM_HOST=0.0.0.0
VULNOGRAM_PORT=3555
# Directory where CVE attachments are stored. Setting this enables the attachments
# feature for the cve5 section. Must match the volume mount path in docker-compose.yml.
VULNOGRAM_FILES_DIR=/home/vulnogram/files
# Stable secret for signing session cookies. REQUIRED in production and must be
# IDENTICAL on every instance: a per-instance generated secret breaks sessions
# across instances and causes random "invalid csrf token" errors. If unset, a
# secret is generated and persisted to config/.session-secret (single-node only).
#SESSION_SECRET=change-me-to-a-long-random-string
# Express "trust proxy" when running behind a reverse proxy / load balancer.
# Values: true | false | hop count (e.g. 1) | IP/subnet or comma list.
#TRUST_PROXY=1
# Redis (optional): shared session store + query cache. Points at the redis
# service in docker-compose. When unset, sessions fall back to MongoDB and the
# query cache is disabled (the app still works, just uncached).
REDIS_URL=redis://vulnogram-redis:6379
# Session store selection: auto (Redis when REDIS_URL set, else Mongo) | redis | mongo
#SESSION_STORE=auto
# Query cache tuning (effective only when REDIS_URL is set).
#QUERY_CACHE=true
#QUERY_CACHE_TTL=45
#QUERY_CACHE_TTL_NVD=3600
#REDIS_MAXMEMORY=256mb
#REDIS_MAXMEMORY_POLICY=allkeys-lru
# OIDC single sign-on (optional). Works with any compliant IdP via discovery
# (Keycloak, Authentik, Entra/Azure AD, Okta, Google, ...). Local login stays on.
# New SSO users are created just-in-time and linked to an existing local account
# with the same email. callbackURL must be the externally reachable origin.
#OIDC_ENABLED=true
#OIDC_ISSUER=https://keycloak.example.com/realms/main
#OIDC_CLIENT_ID=vulnogram
#OIDC_CLIENT_SECRET=change-me
#OIDC_CALLBACK_URL=https://vulnogram.example.com/users/auth/oidc/callback
#OIDC_SCOPES=openid profile email
#OIDC_ALLOWED_DOMAINS=example.com
#OIDC_REQUIRE_VERIFIED_EMAIL=true
#OIDC_BUTTON_LABEL=Sign in with SSO
