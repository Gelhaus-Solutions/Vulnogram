MONGO_HOST=vulnogram-mongo
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_PORT=27017
# Optional full MongoDB connection URI override.
# When set, this takes precedence over MONGO_HOST/MONGO_PORT/MONGO_INITDB_ROOT_*.
#MONGO_URL=mongodb://admin:admin@vulnogram-mongo:27017
START_COMMAND=node init-vulnogram.js && node app.js
VULNOGRAM_ADMIN_CNA_EMAIL=security@example.com
VULNOGRAM_ADMIN_EMAIL=user@example.com
VULNOGRAM_ADMIN_NAME=Example User
VULNOGRAM_ADMIN_PASSWORD=vulnogram
VULNOGRAM_ADMIN_USERNAME=vulnogram
VULNOGRAM_HOST=0.0.0.0
VULNOGRAM_PORT=3555
# Stable secret for signing session cookies. Set in production so sessions
# survive restarts and work across multiple processes. If unset, a secret is
# generated and persisted to config/.session-secret.
#SESSION_SECRET=change-me-to-a-long-random-string
# Express "trust proxy" when running behind a reverse proxy / load balancer.
# Values: true | false | hop count (e.g. 1) | IP/subnet or comma list.
#TRUST_PROXY=1
