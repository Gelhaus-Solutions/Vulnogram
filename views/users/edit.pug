extends ../layout

block append topHeaderLeft
  if admin
    a.btn.sfe.vgi-magic(href="/users/profile") Add user
  a.fbn.vgi-user(href="/users/list") User list

block content
 div
  - var action = '/users/profile/';
  if profile.username
    - action = action + profile.username;
  form.pad2(method='POST', action=action)
    input(type='hidden', name='_csrf', value=csrfToken)
    .row
        h2=title
    .row
      label.lbl.vgi-user Name:
      input.txt(name='name', type='text', value=profile.name)
    .row
      label.lbl.vgi-mail Email:
      input.txt(name='email', type='text', value=profile.email)
    .row
      label.lbl.vgi-user Username:
      if admin
        input.txt(name='username', type='text',value=profile.username)
      else
        tt=profile.username
    .row
      label.lbl.vgi-image Favorite Emoji:
      input.txt(name='emoji', type='text', value=profile.emoji)
    .row
      label.lbl.vgi-key Password:
      input.txt(name='password', type='password', autocomplete="new-password")
    .row
      label.lbl.vgi-key Confirm Password:
      input.txt(name='password2', type='password', autocomplete="new-password")
    if admin
      .row
        label.lbl.vgi-king Instance roles:
        .vflx
          if instanceRoleDefs && instanceRoleDefs.length
            each r in instanceRoleDefs
              label
                input(type="checkbox", name="instanceRoles", value=r.name, checked=(profile.instanceRoles && profile.instanceRoles.indexOf(r.name) >= 0))
                = ' ' + r.name
          else
            span.sml.tgrey (no instance-scoped roles defined)
      .row
        label.lbl.vgi-user Active:
        input(type="checkbox", name="active", checked=(profile.active !== false))
      .row
        label.lbl.vgi-org Team memberships:
        if teamDefs && teamDefs.length
          table.vtbl.wht
            thead
              tr
                th Team
                th Role
            tbody
              each t in teamDefs
                - var current = (profile.teams || []).filter(function(m){return m.team == t.key;})[0]
                - var currentRole = current && current.roles && current.roles.length ? current.roles[0] : ''
                tr
                  td
                    tt= t.key
                    |
                    = t.name
                  td
                    select.form-control(name="teamRole[" + t.key + "]")
                      option(value="", selected=!currentRole) — none —
                      if teamRoleDefs
                        each r in teamRoleDefs
                          option(value=r.name, selected=currentRole == r.name)= r.name
        else
          span.sml.tgrey (no teams defined — create one under Admin → Teams)
    else
      .row
        label.lbl.vgi-org Teams:
        tt
          if profile.teams && profile.teams.length
            = profile.teams.map(function(t){return t.team + ' (' + (t.roles||[]).join(', ') + ')';}).join('; ')
          else
            | (no team)
      .row
        label.lbl.vgi-king Instance role:
        tt
          if profile.instanceRoles && profile.instanceRoles.length
            = profile.instanceRoles.join(', ')
          else
            | Member
    .gap
        button.btn.sfe(type='submit', value='Save') Save
        if admin && profile.username
          a.fbn.vgi-del.dis(href="/users/delete/"+profile.username,onclick="return confirm('Delete this user?')") Delete 
            = profile.username    

                
        

    