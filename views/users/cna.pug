//- Saved CNA login profiles (metadata only — the API key is never stored).
extends ../layout

block append topHeaderLeft
  a.fbn.vgi-user(href="/users/profile/" + user.username) Profile

block content
  .pad2
    h2 CNA logins
    p.tgrey Saved CVE Services login profiles (org, user, portal). These are stored on the server without your API key. Pick a saved login in the portal login box to prefill these fields. Optionally, the portal login box has a "Remember API key on this device" option that stores your key encrypted in this browser only (never on the server) for auto-login; it is cleared when you log out.
    table.vtbl.wht
      thead
        tr
          th Label
          th Org
          th User
          th Portal
          th
      tbody
        each p in profiles
          tr
            td= p.label
            td= p.org
            td= p.user
            td.sml= p.serviceUrl
            td
              form(method="POST", action="/users/cna/" + p.id + "/delete", onsubmit="return confirm('Remove this CNA login?')")
                input(type="hidden", name="_csrf", value=csrfToken)
                button.fbn.vgi-del(type="submit") Remove
        if !profiles || !profiles.length
          tr
            td(colspan=5)
              span.sml.tgrey No saved CNA logins yet.
    h3.pad Add a login
    form.pad2(method="POST", action="/users/cna")
      input(type="hidden", name="_csrf", value=csrfToken)
      .row
        label.lbl.vgi-tag Label:
        input.txt(name="label", type="text", placeholder="e.g. ACME prod")
      .row
        label.lbl.vgi-org Org short name:
        input.txt(name="org", type="text", required=true)
      .row
        label.lbl.vgi-user CVE user:
        input.txt(name="user", type="text", required=true)
      .row
        label.lbl.vgi-globe Portal:
        select.form-control(name="serviceUrl")
          each s in portalUrls
            option(value=s.url)= s.label + ' (' + s.url + ')'
      .gap
        button.btn.sfe(type="submit") Save login
