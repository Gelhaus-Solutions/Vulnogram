//- Create / edit a role (capability bundle).
extends ../layout

block content
  include adminnav
  - var action = isNew ? '/admin/roles/new' : '/admin/roles/' + encodeURIComponent(role.name)
  - var caps = role.capabilities || []
  form.pad2(method="POST", action=action)
    input(type="hidden", name="_csrf", value=csrfToken)
    h2= title
    .row
      label.lbl.vgi-crown Name:
      if isNew
        input.txt(name="name", type="text", value=role.name)
      else
        tt= role.name
        if role.builtin
          span.sml.tgrey  (built-in)
    .row
      label.lbl.vgi-knob Scope:
      select.form-control(name="scope")
        option(value="team", selected=role.scope=='team') team
        option(value="instance", selected=role.scope=='instance') instance
    .row
      label.lbl Capabilities:
      .vflx
        label
          input(type="checkbox", name="wildcard", checked=(caps.indexOf(wildcard) >= 0))
          |  * (all capabilities / superuser)
        each cap in allCapabilities
          label
            input(type="checkbox", name="capabilities", value=cap, checked=(caps.indexOf(cap) >= 0))
            = ' ' + cap
    .gap
      button.btn.sfe(type="submit") Save role
      a.fbn.vgi-undo(href="/admin/roles") Cancel
